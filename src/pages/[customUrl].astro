---
export const prerender = false;

import Layout from '../layouts/Layout.astro';

const { customUrl } = Astro.params;
---

<Layout title="Shared List - The Urlist">
	<main class="min-h-screen bg-gray-100 py-8">
		<div class="max-w-4xl mx-auto px-4">
			<div id="list-container"></div>
		</div>
	</main>

	<script define:vars={{ customUrl }}>
		async function loadSharedList() {
			try {
				const response = await fetch(`/api/share/${customUrl}`);
				const data = await response.json();
				
				if (!data.success) {
					document.getElementById('list-container').innerHTML = `
						<div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
							<p class="font-bold">List not found</p>
							<p>This list may have been deleted or is not published yet.</p>
						</div>
					`;
					return;
				}

				const { list, items } = data;
				const container = document.getElementById('list-container');
				
				container.innerHTML = `
					<div class="mb-8">
						<div class="bg-gradient-to-r from-indigo-600 to-indigo-800 text-white p-6 rounded-lg shadow-lg mb-8">
							<h1 class="text-4xl font-bold mb-2">${list.title}</h1>
							${list.description ? `<p class="text-indigo-100 text-lg">${list.description}</p>` : ''}
							
							<div class="bg-indigo-700 p-4 rounded-lg mt-4">
								<p class="text-sm text-indigo-100 mb-2">Share this list:</p>
								<div class="flex items-center gap-2">
									<code class="flex-1 bg-indigo-900 p-2 rounded text-sm break-all">${window.location.href}</code>
									<button onclick="copyShareUrl('${window.location.href}')" class="bg-indigo-600 hover:bg-indigo-500 text-white py-2 px-4 rounded font-medium">Copy</button>
								</div>
							</div>
						</div>

						<div id="items-container">
							<h2 class="text-2xl font-bold text-gray-900 mb-4">URLs in this list</h2>
							${items.length === 0 ? '<p class="text-gray-600">This list is empty.</p>' : ''}
							<div class="space-y-3">
								${items.map(item => `
									<div class="bg-white p-4 rounded-lg shadow-md border-l-4 border-indigo-500 hover:shadow-lg transition-shadow">
										<div>
											${item.title ? `<p class="text-sm font-medium text-gray-700 mb-1">${item.title}</p>` : ''}
											<a href="${item.url}" target="_blank" rel="noopener noreferrer" class="text-indigo-600 hover:text-indigo-800 break-all text-sm">${item.url}</a>
											<p class="text-xs text-gray-500 mt-2">Added ${new Date(item.created_at).toLocaleDateString()}</p>
										</div>
									</div>
								`).join('')}
							</div>
						</div>
					</div>
				`;
			} catch (error) {
				console.error('Error loading list:', error);
				document.getElementById('list-container').innerHTML = '<div class="text-red-600">Error loading list. Please try again.</div>';
			}
		}

		function copyShareUrl(url) {
			navigator.clipboard.writeText(url);
			alert('Link copied to clipboard!');
		}

		loadSharedList();
	</script>
</Layout>