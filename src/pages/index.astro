---
import Layout from '../layouts/Layout.astro';
---

<Layout title="The Urlist - Share Your URLs">
	<main class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100">
		<!-- Navigation Shortcuts -->
		<section class="max-w-4xl mx-auto px-4 py-6">
			<div class="flex justify-center gap-4 flex-wrap">
				<a href="/my-lists" class="bg-white text-indigo-600 border-2 border-indigo-600 py-2 px-6 rounded-lg hover:bg-indigo-50 font-medium">
					📋 My Lists
				</a>
			</div>
		</section>

		<!-- Hero Section -->
		<section class="max-w-4xl mx-auto px-4 py-20 text-center">
			<h1 class="text-5xl font-bold text-gray-900 mb-4">
				Welcome to <span class="text-indigo-600">Urlist</span>
			</h1>
			<p class="text-xl text-gray-700 mb-8">
				Create, organize, and share collections of URLs with ease. Perfect for curating resources, bookmarks, and recommendations.
			</p>
			<div class="flex gap-4 justify-center flex-wrap">
				<a href="/create" class="bg-indigo-600 text-white py-3 px-8 rounded-lg font-bold hover:bg-indigo-700 transition">
					Create a List
				</a>
				<a href="/#features" class="bg-white text-indigo-600 border-2 border-indigo-600 py-3 px-8 rounded-lg font-bold hover:bg-indigo-50 transition">
					Learn More
				</a>
			</div>
		</section>

		<!-- Features Section -->
		<section id="features" class="max-w-4xl mx-auto px-4 py-20">
			<h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Features</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="bg-white p-6 rounded-lg shadow-md">
					<div class="text-3xl mb-4">📝</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">Create Lists</h3>
					<p class="text-gray-700">Start with an empty list and begin adding URLs. Give your list a custom name and description.</p>
				</div>
				<div class="bg-white p-6 rounded-lg shadow-md">
					<div class="text-3xl mb-4">🔗</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">Add & Manage URLs</h3>
					<p class="text-gray-700">Easily add, edit, and delete URLs from your list. Keep everything organized and up-to-date.</p>
				</div>
				<div class="bg-white p-6 rounded-lg shadow-md">
					<div class="text-3xl mb-4">🌐</div>
					<h3 class="text-xl font-bold text-gray-900 mb-2">Share Publicly</h3>
					<p class="text-gray-700">Get a shareable link with a custom URL. Share your curated collection with anyone.</p>
				</div>
			</div>
		</section>

		<!-- CTA Section -->
		<section class="bg-indigo-600 text-white py-20">
			<div class="max-w-2xl mx-auto text-center px-4">
				<h2 class="text-3xl font-bold mb-4">Ready to Create Your First List?</h2>
				<p class="text-lg mb-8 text-indigo-100">Start organizing your URLs today. It's free and takes just seconds.</p>
				<a href="/create" class="bg-white text-indigo-600 py-3 px-8 rounded-lg font-bold hover:bg-indigo-50 transition inline-block">
					Get Started
				</a>
			</div>
		</section>
	</main>
</Layout>
</Layout>
