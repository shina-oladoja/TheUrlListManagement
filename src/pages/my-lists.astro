---
import Layout from '../layouts/Layout.astro';
import MyListsComponent from '../components/MyListsComponent';
---

<Layout title="My Lists - The Urlist">
	<main class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 py-20">
		<div class="max-w-6xl mx-auto px-4">
			<div class="mb-12">
				<h1 class="text-4xl font-bold text-gray-900 mb-2">My Lists</h1>
				<p class="text-gray-700 text-lg">Manage your URL collections</p>
			</div>

			<div class="mb-8 flex gap-4">
				<a href="/create" class="bg-indigo-600 text-white py-3 px-6 rounded-lg hover:bg-indigo-700 font-bold transition">
					+ Create New List
				</a>
				<a href="/" class="bg-white text-indigo-600 border-2 border-indigo-600 py-3 px-6 rounded-lg hover:bg-indigo-50 font-bold transition">
					← Back to Home
				</a>
			</div>

			<div class="bg-white p-8 rounded-lg shadow-md">
				<MyListsComponent client:load />
			</div>
		</div>
	</main>
</Layout>
