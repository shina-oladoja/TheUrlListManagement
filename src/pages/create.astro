---
import Layout from '../layouts/Layout.astro';
import ListForm from '../components/ListForm';
---

<Layout title="Create a New List - The Urlist">
	<main class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 py-20">
		<div class="max-w-2xl mx-auto px-4">
			<div class="mb-8">
				<h1 class="text-4xl font-bold text-gray-900 mb-2">Create a New List</h1>
				<p class="text-gray-700 text-lg">Start curating your URL collection today</p>
			</div>

			<ListForm client:load />

			<div class="mt-12 bg-white p-6 rounded-lg shadow-md">
				<h2 class="text-2xl font-bold text-gray-900 mb-4">Next Steps</h2>
				<ol class="space-y-3 text-gray-700">
					<li class="flex gap-3">
						<span class="bg-indigo-600 text-white rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0">1</span>
						<span>Create your list with a title and optional description</span>
					</li>
					<li class="flex gap-3">
						<span class="bg-indigo-600 text-white rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0">2</span>
						<span>Add URLs to your list and give them titles</span>
					</li>
					<li class="flex gap-3">
						<span class="bg-indigo-600 text-white rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0">3</span>
						<span>Publish your list to make it shareable</span>
					</li>
					<li class="flex gap-3">
						<span class="bg-indigo-600 text-white rounded-full w-6 h-6 flex items-center justify-center flex-shrink-0">4</span>
						<span>Share the link with others!</span>
					</li>
				</ol>
			</div>
		</div>
	</main>
</Layout>