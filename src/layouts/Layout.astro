---
import '../styles/global.css'

interface Props {
	title: string;
}

const { title = 'The Urlist' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content="Create, organize, and share collections of URLs with ease." />
	</head>
	<body class="bg-gray-50">
		<nav class="bg-white shadow-md">
			<div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
				<a href="/" class="text-2xl font-bold text-indigo-600">Urlist</a>
				<div class="flex gap-4">
					<a href="/" class="text-gray-700 hover:text-indigo-600">Home</a>
					<a href="/my-lists" class="text-gray-700 hover:text-indigo-600">My Lists</a>
					<a href="/create" class="bg-indigo-600 text-white py-2 px-4 rounded-lg hover:bg-indigo-700">Create List</a>
				</div>
			</div>
		</nav>
		<slot />
		<footer class="bg-gray-800 text-white py-8 mt-12">
			<div class="max-w-7xl mx-auto px-4 text-center">
				<p>&copy; 2026 The Urlist. Share your URLs, curate collections.</p>
			</div>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
	}
</style>
